<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VibeStore | Premium Essentials</title>
    <link rel="stylesheet" href="shop-style.css">
    <script src="https://unpkg.com/lucide@latest"></script> </head>
<style>
:root {
    --accent: #ff4757;
    --dark: #2f3542;
    --light: #f1f2f6;
    --white: #ffffff;
}

body {
    font-family: 'Inter', sans-serif;
    background-color: var(--white);
    margin: 0;
}

.promo-bar {
    background: var(--dark);
    color: white;
    text-align: center;
    padding: 8px;
    font-size: 0.9rem;
}

nav {
    display: flex;
    justify-content: space-between;
    padding: 20px 5%;
    align-items: center;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
}

.logo { font-weight: 900; font-size: 1.5rem; letter-spacing: -1px; }
.logo span { color: var(--accent); }

.nav-links { display: flex; list-style: none; gap: 30px; }
.nav-links a { text-decoration: none; color: var(--dark); font-weight: 600; }

.nav-icons { display: flex; gap: 20px; align-items: center; cursor: pointer; }
.cart-icon { position: relative; }
#cart-count {
    position: absolute;
    top: -8px; right: -10px;
    background: var(--accent);
    color: white;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 50%;
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 30px;
    padding: 40px 5%;
}

.product-card {
    border-radius: 15px;
    overflow: hidden;
    transition: 0.3s;
}

.product-card:hover { transform: translateY(-5px); }

.img-container {
    background: #f9f9f9;
    height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
}

.add-btn {
    position: absolute;
    bottom: 15px;
    right: 15px;
    background: var(--white);
    border: none;
    padding: 10px;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.info { padding: 15px 0; }
.info h4 { margin: 0; font-size: 1.1rem; }
.price { color: var(--accent); font-weight: bold; }

</style>
<body>
    <div class="promo-bar">Free Shipping on orders over $50! 🚀</div>
    
    <header>
        <nav>
            <div class="logo">VIBE<span>STORE</span></div>
            <ul class="nav-links">
                <li><a href="#">New Arrivals</a></li>
                <li><a href="#">Men</a></li>
                <li><a href="#">Women</a></li>
            </ul>
            <div class="nav-icons">
                <i data-lucide="search"></i>
                <div class="cart-icon">
                    <i data-lucide="shopping-bag"></i>
                    <span id="cart-count">0</span>
                </div>
            </div>
        </nav>
    </header>

    <section class="hero-shop">
        <div class="hero-text">
            <h2>Summer Collection 2026</h2>
            <p>Elevate your daily routine with our curated essentials.</p>
            <button class="shop-now">Shop All</button>
        </div>
    </section>

    <main class="container">
        <div class="filter-bar">
            <h3>Our Products</h3>
            <select>
                <option>Sort by: Featured</option>
                <option>Price: Low to High</option>
                <option>Newest</option>
            </select>
        </div>

        <div class="product-grid" id="product-grid">
            </div>
    </main>

    <script src="shop-logic.js"></script>
    <script>lucide.createIcons();</script>
</body>
</html>

